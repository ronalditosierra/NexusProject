---
// Puedes importar tu imagen local aquí si tienes una. Por ejemplo:
// import fondoImg from '../assets/Añadidos/3.png';
import { Image } from "astro:assets";
import Blobs from "../assets/Añadidos/Blobs.svg";
---

<div
    class="w-full px-4 sm:px-8 py-12 flex justify-center border-b border-slate-200"
>
    <section
        class="relative flex flex-col items-center justify-center w-full max-w-5xl text-center rounded-3xl py-20 px-6 md:py-24 shadow-xl overflow-hidden"
        style={`background-image: url('${Blobs.src}'); background-size: cover; background-position: center; background-repeat: no-repeat;`}
    >
        <!-- Overlay semitransparente para que el texto sea más legible sobre la imagen de fondo -->
        <div class="absolute inset-0 bg-black/30 z-0"></div>

        <div class="relative z-10 flex flex-col items-center justify-center">
            <h1
                class="text-2xl sm:text-3xl md:text-4xl font-['Alfa_Slab_One'] text-white max-w-4xl leading-relaxed drop-shadow-md"
            >
                “El niño crea sus propios movimientos y, una vez creados, los
                perfecciona."
            </h1>

            <div
                class="h-[3px] w-32 my-6 bg-linear-to-r from-transparent via-white to-transparent opacity-80"
            >
            </div>

            <p
                class="text-xl md:text-2xl font-sans text-gray-200 font-medium drop-shadow-sm"
            >
                Maria Montessori
            </p>
        </div>
    </section>
</div>
